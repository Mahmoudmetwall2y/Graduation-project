# ========================================
# AscultiCor Cloud VM Environment
# One private/staging VM running:
# frontend + inference + mosquitto + nginx + optional n8n
# ========================================

# ========================================
# Public application domain
# ========================================
APP_DOMAIN=app.example.com
N8N_DOMAIN=n8n.example.com
DEVICE_BOOTSTRAP_PUBLIC_BASE_URL=https://app.example.com

# ========================================
# Supabase (Required)
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# MQTT Broker
# Keep local-only for dashboard collaboration by default.
# If real ESP32 devices must connect to the cloud VM directly,
# set MQTT_BIND_ADDRESS=0.0.0.0 only after adding TLS/VPN/proxy hardening.
# ========================================
MQTT_USERNAME=replace-with-strong-admin-user
MQTT_PASSWORD=replace-with-strong-admin-password
MQTT_BIND_ADDRESS=127.0.0.1
MQTT_WS_BIND_ADDRESS=127.0.0.1
MQTT_TCP_PORT=1883
MQTT_WS_PORT=9001
MQTT_DEVICE_PASSWORD_PEPPER=replace-with-a-long-random-secret
MQTT_SYNC_INTERVAL_SEC=15
DEVICE_BOOTSTRAP_MQTT_HOST=app.example.com
DEVICE_BOOTSTRAP_MQTT_PORT=1883
DEVICE_BOOTSTRAP_MQTT_TLS=false

# ========================================
# Internal service exposure
# Only NGINX should be public on the VM.
# ========================================
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=3000
INFERENCE_BIND_ADDRESS=127.0.0.1
INFERENCE_PORT=8000
NGINX_HTTP_BIND_ADDRESS=0.0.0.0
NGINX_HTTP_PORT=80
NGINX_HTTPS_BIND_ADDRESS=0.0.0.0
NGINX_HTTPS_PORT=443
NGINX_SERVER_NAME=app.example.com
NGINX_SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
NGINX_SSL_KEY_PATH=/etc/nginx/certs/privkey.pem
NGINX_N8N_SERVER_NAME=n8n.example.com
NGINX_N8N_SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
NGINX_N8N_SSL_KEY_PATH=/etc/nginx/certs/privkey.pem

# ========================================
# ML Model Settings
# ========================================
PCG_SAMPLE_RATE=22050
PCG_TARGET_DURATION=10
PCG_MAX_DURATION=20
ECG_SAMPLE_RATE=500
ECG_WINDOW_SIZE=500
ECG_MAX_WINDOWS=12
ECG_MAX_DURATION=60
STREAM_TIMEOUT_SEC=20
METRICS_UPDATE_HZ=10
DEVICE_DEFAULT_SESSION_DURATION_SEC=15
ENABLE_DEMO_MODE=false
LOG_LEVEL=INFO

# ========================================
# App security / internal tokens
# ========================================
INTERNAL_API_TOKEN=replace-with-a-long-random-token
INFERENCE_INTERNAL_TOKEN=replace-with-another-long-random-token
ALLOWED_ORIGINS=https://app.example.com
TRUSTED_HOSTS=app.example.com,localhost,127.0.0.1
DEFAULT_SIGNUP_ORG_ID=
SECURITY_HEADERS_ENABLED=true
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co;"

# ========================================
# LLM provider
# ========================================
LLM_PROVIDER=demo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ========================================
# Supabase Edge Functions
# ========================================
CORS_ORIGIN=https://app.example.com

# ========================================
# Optional n8n cloud profile
# Used with: docker compose -f docker-compose.yml -f docker-compose.cloud.yml up -d
# Keep bound to loopback unless you intentionally proxy it.
# ========================================
N8N_BIND_ADDRESS=127.0.0.1
N8N_PORT=5678
N8N_USER=automation-admin
N8N_PASSWORD=replace-with-a-strong-password
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
GENERIC_TIMEZONE=Africa/Cairo
N8N_EDITOR_BASE_URL=https://n8n.example.com
N8N_WEBHOOK_URL=https://n8n.example.com/
N8N_PROXY_HOPS=1
