# ========================================
# AscultiCor Environment Configuration
# ========================================
# SECURITY WARNING: This file should not contain real credentials.
# - Keep .env in .gitignore at all times
# - Rotate keys immediately if accidentally exposed
# - Use strong, unique passwords for production
# ========================================

# ========================================
# SUPABASE (Required)
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========================================
# MQTT Broker (Local Development)
# ========================================
MQTT_USERNAME=asculticor
MQTT_PASSWORD=change-me-in-production-use-strong-password
MQTT_BIND_ADDRESS=127.0.0.1
MQTT_WS_BIND_ADDRESS=127.0.0.1
MQTT_TCP_PORT=1883
MQTT_WS_PORT=9001
MQTT_DEVICE_PASSWORD_PEPPER=replace-with-a-long-random-secret
MQTT_SYNC_INTERVAL_SEC=15

# Device bootstrap / LAN access
# Set DEVICE_BOOTSTRAP_PUBLIC_BASE_URL to the URL reachable by ESP32 devices.
# Example: http://192.168.1.100 or https://asculticor.local
DEVICE_BOOTSTRAP_PUBLIC_BASE_URL=
DEVICE_BOOTSTRAP_MQTT_HOST=
DEVICE_BOOTSTRAP_MQTT_PORT=1883
DEVICE_BOOTSTRAP_MQTT_TLS=false

# Reverse proxy / host exposure
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=3000
INFERENCE_BIND_ADDRESS=127.0.0.1
INFERENCE_PORT=8000
NGINX_HTTP_BIND_ADDRESS=0.0.0.0
NGINX_HTTP_PORT=80
NGINX_HTTPS_BIND_ADDRESS=0.0.0.0
NGINX_HTTPS_PORT=443
NGINX_SERVER_NAME=localhost
NGINX_SSL_CERT_PATH=/etc/nginx/certs/selfsigned.crt
NGINX_SSL_KEY_PATH=/etc/nginx/certs/selfsigned.key

# ========================================
# ML Model Settings (Optional - Has Defaults)
# ========================================
PCG_SAMPLE_RATE=22050
PCG_TARGET_DURATION=10
PCG_MAX_DURATION=20
ECG_SAMPLE_RATE=500
ECG_WINDOW_SIZE=500
ECG_MAX_WINDOWS=12
ECG_MAX_DURATION=60
STREAM_TIMEOUT_SEC=20
METRICS_UPDATE_HZ=10
DEVICE_DEFAULT_SESSION_DURATION_SEC=15

# ========================================
# Demo Mode (Development Only)
# ========================================
# SECURITY: Disable in production!
ENABLE_DEMO_MODE=true

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO

# Internal API token (for scheduled/background LLM processing endpoint)
INTERNAL_API_TOKEN=replace-with-a-long-random-token
# Internal token for inference /config and /metrics endpoints
INFERENCE_INTERNAL_TOKEN=replace-with-another-long-random-token

# ========================================
# CORS (Frontend URL)
# ========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
TRUSTED_HOSTS=*.asculticor.com,localhost,127.0.0.1

# Signup onboarding
# Leave blank to require admin/invite-only onboarding.
DEFAULT_SIGNUP_ORG_ID=

# ========================================
# Rate Limiting (Production Security)
# ========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5

# ========================================
# Security Headers
# ========================================
SECURITY_HEADERS_ENABLED=true
CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co;"

# ========================================
# LLM Integration (Optional)
# ========================================
# LLM_PROVIDER controls which report generator is used.
# - demo: template-based reports (default)
# - openai: placeholder for OpenAI integration (implement before use)
# - gemini: placeholder for Gemini integration (implement before use)
LLM_PROVIDER=demo

# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4
# GOOGLE_API_KEY=your-google-api-key-here
# GEMINI_MODEL=gemini-pro

# ========================================
# n8n (Optional cloud automation profile)
# ========================================
# Used only with: docker compose -f docker-compose.yml -f docker-compose.cloud.yml up -d
N8N_BIND_ADDRESS=127.0.0.1
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=change-me
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
GENERIC_TIMEZONE=Africa/Cairo
N8N_WEBHOOK_URL=
N8N_PROXY_HOPS=1

# ========================================
# Edge Function CORS (Optional)
# ========================================
# Comma-separated list of allowed origins for Supabase Edge Functions.
# CORS_ORIGIN=http://localhost:3000,https://your-app.example.com
CORS_ORIGIN=http://localhost:3000
